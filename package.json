{
  "name": "topshop-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-output.mjs",
    "dev": "next dev",
    "gallery:optimize": "node scripts/optimize-gallery-images.mjs",
